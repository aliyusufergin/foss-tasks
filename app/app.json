{
  "expo": {
    "name": "foss-tasks",
    "slug": "foss-tasks",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "foss-tasks",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.foss-tasks.client"
    },
    "android": {
      "package": "app.foss_tasks.client"
    },
    "plugins": [
      "expo-dev-client",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
