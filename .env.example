# Copy to .env and fill in. `docker compose` reads .env automatically.
# Do NOT commit your real .env (see .gitignore). Change every "change-me" value.

# --- Source Postgres (source of truth) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-source-password
POSTGRES_DB=foss_tasks
# Host port to expose the source DB on (optional; container port is always 5432).
POSTGRES_PORT=5432

# Password for the powersync_replication role (REPLICATION + BYPASSRLS) that the
# PowerSync Service connects as. Created by infra/postgres/init/02-powersync.sh.
POWERSYNC_REPLICATION_PASSWORD=change-me-replication-password

# --- PowerSync bucket-storage Postgres (separate instance, ADR-0007) ---
BUCKET_POSTGRES_USER=powersync_storage
BUCKET_POSTGRES_PASSWORD=change-me-bucket-password
BUCKET_POSTGRES_DB=powersync_storage

# --- PowerSync Service ---
PS_PORT=8080
# Admin/diagnostics API token. Change for any non-local deployment.
PS_ADMIN_API_TOKEN=change-me-admin-token

# --- Auth service ---
AUTH_PORT=6060
AUTH_JWT_ISSUER=foss-tasks-auth
# Must match client_auth.audience in infra/powersync/service.yaml.
AUTH_JWT_AUDIENCE=powersync
AUTH_JWT_KID=auth-key-1
AUTH_JWT_TTL_SECONDS=3600
# RS256 private key (PKCS8 PEM). Generate with:
#   cd services/auth && npm install && npm run gen-keys
# Paste as a single line with literal \n between PEM lines, e.g.:
#   AUTH_JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n
AUTH_JWT_PRIVATE_KEY=
